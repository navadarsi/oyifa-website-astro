---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
import { URLS } from '../config/urls';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isArabic = lang === 'ar';

const currentPath = Astro.url.pathname.replace(`/${lang}`, '').replace(/^\/ar/, '') || '/';
const alternateLangPath = getLocalizedPath(currentPath, isArabic ? 'en' : 'ar');
const alternateLangLabel = isArabic ? 'English' : 'العربية';

// Logo based on language
const logoSrc = isArabic ? '/assets/images/logo_arabic.png' : '/assets/images/logo_english.png';
const logoAlt = isArabic ? 'شعار أويفا' : 'Oyifa Logo';

const currentYear = new Date().getFullYear();

// Social links — Lucide icon paths inlined to match the site's inline-SVG convention (no icon dependency)
const socialLinks = [
  {
    name: 'LinkedIn',
    href: 'https://www.linkedin.com/company/oyifa',
    icon: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>',
  },
  {
    name: 'Instagram',
    href: 'https://www.instagram.com/oyifatenderportal',
    icon: '<rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>',
  },
  {
    name: 'Facebook',
    href: 'https://www.facebook.com/oyifatenderportal',
    icon: '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>',
  },
  {
    name: 'YouTube',
    href: 'https://www.youtube.com/@Oyifa',
    icon: '<path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/>',
  },
];
---

<footer
  class="bg-white py-12 border-t border-gray-200"
  role="contentinfo"
  aria-label={isArabic ? 'تذييل الموقع' : 'Site footer'}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid gap-8 md:grid-cols-3">
      <!-- Brand Column -->
      <div>
        <div class="mb-4">
          <a href={getLocalizedPath('/', lang)}>
            <img
              src={logoSrc}
              alt={logoAlt}
              width="120"
              height="40"
              class="object-contain h-10 w-auto"
            />
          </a>
        </div>
        <p class="text-sm text-gray-500 mb-4">
          {t('footer.description')}
        </p>
        <a
          href={`${URLS.app}/register`}
          class="btn btn-primary btn-sm inline-flex items-center gap-2"
          aria-label={isArabic ? 'ابدأ مع أويفا اليوم' : 'Get started with Oyifa today'}
        >
          {t('footer.get_started')}
          <svg
            class={`w-3 h-3 ${isArabic ? 'rotate-180' : ''}`}
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
          </svg>
        </a>

        <!-- Social links -->
        <div class="mt-6 flex items-center gap-4">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-400 hover:text-primary transition-colors"
              aria-label={`${isArabic ? 'أويفا على' : 'Oyifa on'} ${social.name}`}
            >
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={social.icon}
              ></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Platform Column -->
      <div>
        <h3 class="mb-4 text-lg font-bold text-gray-900">
          {t('footer.platform')}
        </h3>
        <nav aria-label={isArabic ? 'قائمة المنصة' : 'Platform navigation'}>
          <ul class="space-y-2 text-sm">
            <li>
              <a
                href={`${URLS.app}/register/client`}
                class="text-gray-500 hover:text-primary transition-colors"
              >
                {t('footer.platform.post')}
              </a>
            </li>
            <li>
              <a
                href={`${URLS.app}/register/vendor`}
                class="text-gray-500 hover:text-primary transition-colors"
              >
                {t('footer.platform.find')}
              </a>
            </li>
            <li>
              <a
                href={getLocalizedPath('/pricing', lang)}
                class="text-gray-500 hover:text-primary transition-colors"
              >
                {t('footer.platform.pricing')}
              </a>
            </li>
          </ul>
        </nav>
      </div>

      <!-- Company Column -->
      <div>
        <h3 class="mb-4 text-lg font-bold text-gray-900">
          {t('footer.company')}
        </h3>
        <nav aria-label={isArabic ? 'معلومات الشركة' : 'Company information navigation'}>
          <ul class="space-y-2 text-sm">
            <li>
              <a
                href={getLocalizedPath('/about', lang)}
                class="text-gray-500 hover:text-primary transition-colors"
              >
                {t('footer.company.about')}
              </a>
            </li>
            <li>
              <a
                href={getLocalizedPath('/contact', lang)}
                class="text-gray-500 hover:text-primary transition-colors"
              >
                {t('footer.company.contact')}
              </a>
            </li>
            <li>
              <a
                href={getLocalizedPath('/faq', lang)}
                class="text-gray-500 hover:text-primary transition-colors"
              >
                {t('footer.company.faq')}
              </a>
            </li>
            <li>
              <a
                href={getLocalizedPath('/refund', lang)}
                class="text-gray-500 hover:text-primary transition-colors"
              >
                {t('footer.company.refund')}
              </a>
            </li>
            <li>
              <a
                href={getLocalizedPath('/privacy', lang)}
                class="text-gray-500 hover:text-primary transition-colors"
              >
                {t('footer.company.privacy')}
              </a>
            </li>
            <li>
              <a
                href={getLocalizedPath('/terms', lang)}
                class="text-gray-500 hover:text-primary transition-colors"
              >
                {t('footer.company.terms')}
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-8 pt-8 border-t border-gray-200">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="text-sm text-gray-500 mb-4 md:mb-0">
          {t('footer.copyright')}
        </div>
        <div class="flex flex-col md:flex-row items-center gap-4">
          <a
            href={alternateLangPath}
            class="text-sm text-gray-500 hover:text-primary transition-colors"
          >
            {alternateLangLabel}
          </a>
          <address class="flex items-center text-sm text-gray-500 not-italic">
            <div class="flex items-center gap-1">
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
              <a
                href="mailto:info@oyifa.com"
                class="hover:text-primary transition-colors"
                aria-label={isArabic ? 'البريد الإلكتروني للدعم' : 'Email support'}
              >
                info@oyifa.com
              </a>
            </div>
          </address>
        </div>
      </div>
    </div>
  </div>
</footer>
