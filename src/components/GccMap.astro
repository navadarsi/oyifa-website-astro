---
/**
 * GccMap — detailed decorative map of the six GCC states
 * (Saudi Arabia, UAE, Oman, Qatar, Kuwait, Bahrain).
 *
 * Geometry is extracted from a single Robinson-projected world map, so every
 * country sits in its true relative position with high-fidelity coastlines and
 * faint internal (administrative) borders. Source frame is 1000x507; we crop to
 * a tight viewBox around the Gulf.
 *
 * Layers (back to front):
 *   1. soft brand-gradient fill of the landmass (always-visible base)
 *   2. a light band that sweeps across, clipped to the landmass (shimmer)
 *   3. faint coast + administrative outlines (the "detail")
 *   4. a pulsing city-node network across the Gulf (Riyadh, Kuwait City,
 *      Manama, Doha, Abu Dhabi, Dubai, Muscat)
 *
 * `class` is forwarded to the root <svg> for positioning by the caller.
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg
  class={`gcc-map ${className}`}
  viewBox="563.5 150.5 74.5 53.5"
  preserveAspectRatio="xMidYMid meet"
  fill="none"
  role="img"
  aria-label="Detailed map of the GCC region with major cities"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <!-- Static base fill: primary -> secondary -> accent brand wash -->
    <linearGradient id="gcc-fill" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#421ca4" />
      <stop offset="55%" stop-color="#595cff" />
      <stop offset="100%" stop-color="#5682f9" />
    </linearGradient>

    <!-- Moving highlight band (transparent -> bright light-blue -> transparent) -->
    <linearGradient id="gcc-shine" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#c4ccff" stop-opacity="0" />
      <stop offset="50%" stop-color="#eef1ff" stop-opacity="1" />
      <stop offset="100%" stop-color="#c4ccff" stop-opacity="0" />
    </linearGradient>

    <!-- Gradient stroke for the map border -->
    <linearGradient id="gcc-border" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#5682f9" />
      <stop offset="50%" stop-color="#595cff" />
      <stop offset="100%" stop-color="#6333dc" />
