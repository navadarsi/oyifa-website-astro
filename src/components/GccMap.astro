<style>
  .gcc-map {
    display: block;
    width: 100%;
    height: 100%;
  }

  .gcc-shine-band {
    animation: gcc-pulse 5s ease-in-out infinite;
  }
  @keyframes gcc-pulse {
    0%, 100% { opacity: 0.85; }
    50% { opacity: 1; }
  }

  /* Network links draw themselves in, then idle */
  .gcc-network line {
    stroke-dasharray: 40;
    stroke-dashoffset: 40;
    animation: gcc-draw 1.4s ease-out forwards;
    animation-delay: 0.3s;
  }
  @keyframes gcc-draw {
    to { stroke-dashoffset: 0; }
  }

  /* City nodes pulse in a staggered sequence */
  .gcc-node-halo {
    fill: #5682f9;
    transform-box: fill-box;
    transform-origin: center;
    animation: gcc-ping 3.2s ease-out infinite;
    animation-delay: calc(var(--i) * 0.45s);
  }
  .gcc-node-dot {
    filter: drop-shadow(0 0 0.6px rgba(89, 92, 255, 0.8));
  }
  @keyframes gcc-ping {
    0%   { opacity: 0.55; transform: scale(0.4); }
    70%, 100% { opacity: 0; transform: scale(1.8); }
  }

  @media (prefers-reduced-motion: reduce) {
    .gcc-shine-band { animation: none; opacity: 0; }
    .gcc-network line { animation: none; stroke-dashoffset: 0; }
    .gcc-node-halo { animation: none; opacity: 0.25; }
  }
</style>
