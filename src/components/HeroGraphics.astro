---
/**
 * HeroGraphics — subtle, on-brand accent for the hero (sits behind the video on
 * desktop). Uses the same visual language as the rest of the site: a faint line
 * grid, a soft gradient glow, and a couple of gradient rounded tiles that echo
 * the card / icon-tile motif. No orbiting rings or scattered dots. Decorative.
 *
 * `class` is forwarded to the root <svg> for positioning.
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg
  class={`hero-gfx ${className}`}
  viewBox="0 0 200 200"
  fill="none"
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <radialGradient id="hg-glow" cx="50%" cy="42%" r="55%">
      <stop offset="0%" stop-color="#595cff" stop-opacity="0.30" />
      <stop offset="100%" stop-color="#595cff" stop-opacity="0" />
    </radialGradient>
    <linearGradient id="hg-grad" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#421ca4" />
      <stop offset="100%" stop-color="#5682f9" />
    </linearGradient>
    <pattern id="hg-grid" width="15" height="15" patternUnits="userSpaceOnUse">
      <path d="M15 0H0V15" fill="none" stroke="#421ca4" stroke-opacity="0.16" stroke-width="0.6" />
    </pattern>
    <linearGradient id="hg-fade" x1="0" y1="0" x2="0.9" y2="0.9">
      <stop offset="0%" stop-color="#fff" stop-opacity="0.9" />
      <stop offset="100%" stop-color="#fff" stop-opacity="0" />
    </linearGradient>
    <mask id="hg-fademask">
      <rect x="0" y="0" width="200" height="200" fill="url(#hg-fade)" />
    </mask>
  </defs>

  <!-- Soft gradient glow (ambient, matches the hero blobs) -->
  <ellipse cx="104" cy="90" rx="96" ry="90" fill="url(#hg-glow)" />

  <!-- Faint line grid, faded out diagonally (same texture as the rest of the site) -->
  <g mask="url(#hg-fademask)">
    <rect x="20" y="32" width="164" height="144" rx="18" fill="url(#hg-grid)" />
  </g>

  <!-- Gradient rounded tiles echoing the card / icon-tile motif -->
  <rect x="40" y="116" width="42" height="42" rx="12" fill="url(#hg-grad)" opacity="0.16" />
  <rect x="120" y="46" width="30" height="30" rx="8" fill="url(#hg-grad)" opacity="0.13" />
  <rect x="150" y="122" width="22" height="22" rx="6" fill="url(#hg-grad)" opacity="0.10" />
</svg>
