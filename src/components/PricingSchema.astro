---
/**
 * Product and Offer Schema for Pricing Page
 * Two vendor plans only: Standard and Premium.
 * Prices grouped by currency band: AED (AE/SA/QA), BHD (BH/OM), KWD (KW).
 * Annual price = 10× monthly (two months free).
 */

const standardDesc = "Best for growing vendors. 50 proposal credits per month, 2× profile and proposal visibility, view tenders up to AED 500K, priority support, and advanced analytics.";
const premiumDesc = "For high-volume vendors. Unlimited proposals (fair-use), 5× profile and proposal visibility, view tenders with no value limit, a dedicated account manager, a premium profile badge, and white-glove onboarding.";

const offer = (price, currency, regions, plan, duration) => ({
  "@type": "Offer",
  "name": duration === "P1Y" ? "Annual Subscription" : "Monthly Subscription",
  "price": String(price),
  "priceCurrency": currency,
  "availability": "https://schema.org/InStock",
  "url": `https://app.oyifa.com/register/vendor?plan=${plan}`,
  "priceValidUntil": "2027-12-31",
  "billingIncrement": {
    "@type": "UnitPriceSpecification",
    "billingDuration": duration,
    "billingStart": "0",
  },
  "eligibleRegion": regions,
});

const pricingSchema = {
  "@context": "https://schema.org",
  "@graph": [
    // Standard Plan — Most Popular
    {
      "@type": "Product",
      "@id": "https://oyifa.com/pricing#standard",
      "name": "Oyifa Standard Plan",
      "description": standardDesc,
      "brand": { "@type": "Brand", "name": "Oyifa" },
      "category": "SaaS Platform",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.8",
        "reviewCount": "150",
      },
      "offers": [
        offer(499, "AED", ["AE", "SA", "QA"], "standard", "P1M"),
        offer(4990, "AED", ["AE", "SA", "QA"], "standard", "P1Y"),
        offer(49, "BHD", ["BH", "OM"], "standard", "P1M"),
        offer(490, "BHD", ["BH", "OM"], "standard", "P1Y"),
        offer(39, "KWD", ["KW"], "standard", "P1M"),
        offer(390, "KWD", ["KW"], "standard", "P1Y"),
      ],
    },
    // Premium Plan
    {
      "@type": "Product",
      "@id": "https://oyifa.com/pricing#premium",
      "name": "Oyifa Premium Plan",
      "description": premiumDesc,
      "brand": { "@type": "Brand", "name": "Oyifa" },
      "category": "SaaS Platform",
      "offers": [
        offer(999, "AED", ["AE", "SA", "QA"], "premium", "P1M"),
        offer(9990, "AED", ["AE", "SA", "QA"], "premium", "P1Y"),
        offer(99, "BHD", ["BH", "OM"], "premium", "P1M"),
        offer(990, "BHD", ["BH", "OM"], "premium", "P1Y"),
        offer(79, "KWD", ["KW"], "premium", "P1M"),
        offer(790, "KWD", ["KW"], "premium", "P1Y"),
      ],
    },
  ],
};
---

<!-- Product and Offer Schema for Pricing -->
<script type="application/ld+json" set:html={JSON.stringify(pricingSchema)} />
