---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/utils';
import { URLS } from '../../config/urls';

const t = useTranslations('ar');

// GCC markets — real-world city imagery from across the Gulf (UAE-first rollout)
const gccPlaces = [
  { img: 'uae', name: t('about.gcc.uae'), city: t('about.gcc.uae.city'), blurb: t('about.gcc.uae.blurb'), live: true },
  { img: 'saudi', name: t('about.gcc.saudi'), city: t('about.gcc.saudi.city'), blurb: t('about.gcc.saudi.blurb'), live: false },
  { img: 'qatar', name: t('about.gcc.qatar'), city: t('about.gcc.qatar.city'), blurb: t('about.gcc.qatar.blurb'), live: false },
  { img: 'bahrain', name: t('about.gcc.bahrain'), city: t('about.gcc.bahrain.city'), blurb: t('about.gcc.bahrain.blurb'), live: false },
  { img: 'oman', name: t('about.gcc.oman'), city: t('about.gcc.oman.city'), blurb: t('about.gcc.oman.blurb'), live: false },
  { img: 'kuwait', name: t('about.gcc.kuwait'), city: t('about.gcc.kuwait.city'), blurb: t('about.gcc.kuwait.blurb'), live: false },
];
---

<BaseLayout
  title={t('about.meta.title')}
  description={t('about.meta.desc')}
>
  <Header />

  <main class="flex-1" dir="rtl">
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-gradient-to-br from-primary/10 via-white to-purple-100/10 pt-28 pb-16">
      <!-- Faint GCC skyline backdrop (real-world, subtle parallax) -->
      <img src="/images/gcc/dubai-aerial.webp" alt="Aerial night view of the Dubai skyline" loading="lazy" decoding="async" data-parallax="0.1" class="parallax-media opacity-[0.2]" />
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-white/35 via-white/10 to-white/40"></div>
      <div class="relative z-10 max-w-7xl mx-auto px-4 text-center">
        <span class="inline-flex items-center mb-4 px-3 py-1 bg-purple-100 text-primary rounded-md text-sm font-medium">
          {t('about.hero.badge')}
        </span>
        <!-- OYIFA, expanded: the name we envisioned -->
        <p class="mb-6 text-sm sm:text-base font-bold tracking-[0.12em] text-primary">
          {t('about.hero.tagline')}
        </p>
        <h1 class="mb-6 text-5xl md:text-6xl font-extrabold tracking-tight text-gray-900">
          {t('about.hero.title.part1')}{" "}
          <span class="text-primary">{t('about.hero.title.highlight')}</span>
        </h1>
        <p class="mx-auto mb-8 max-w-4xl text-xl text-gray-500">
          {t('about.hero.desc')}
        </p>
        <div class="mb-8 text-lg text-gray-500 max-w-3xl mx-auto">
          <p>
            {t('about.hero.inspiration')}
          </p>
        </div>
        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="/ar/contact" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary text-white font-medium rounded-md hover:bg-primary/90 transition-colors">
            {t('about.hero.cta.contact')}
            <svg class="h-4 w-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a href={`${URLS.app}/register`} class="inline-flex items-center justify-center px-6 py-3 border border-gray-300 text-gray-700 font-medium rounded-md hover:bg-gray-50 transition-colors">
            {t('about.hero.cta.join')}
          </a>
        </div>
      </div>
    </section>

    <!-- Our Story Section -->
    <section class="pt-12 pb-20 bg-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-12">
            <span class="inline-flex items-center mb-4 px-3 py-1 border border-gray-300 text-gray-600 rounded-md text-sm font-medium">
              {t('about.story.badge')}
            </span>
            <h2 class="text-3xl md:text-4xl font-bold mb-6 text-gray-900">
              {t('about.story.title')}
            </h2>
          </div>

          <div class="space-y-6">
            <!-- The Problem Card -->
            <div class="reveal group relative overflow-hidden rounded-2xl border border-gray-200 bg-white p-7 shadow-sm transition-all duration-300 hover:shadow-xl">
              <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-rose-400 to-red-500"></div>
              <div class="pointer-events-none absolute right-0 top-0 h-24 w-24 text-rose-500/15 gfx-diag" style="-webkit-mask-image:linear-gradient(225deg,#000,transparent);mask-image:linear-gradient(225deg,#000,transparent)"></div>
              <div class="relative">
                <div class="mb-4 flex items-center gap-4">
                  <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-rose-50 text-rose-500 ring-1 ring-inset ring-rose-100">
                    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                  </div>
                  <h3 class="text-lg font-bold text-gray-900">{t('about.story.problem.title')}</h3>
                </div>
                <p class="mb-3 text-lg leading-relaxed text-gray-600">{t('about.story.problem.desc')}</p>
                <p class="font-semibold text-gray-900">{t('about.story.problem.conclusion')}</p>
              </div>
            </div>

            <!-- Backing Card -->
            <div class="reveal group relative overflow-hidden rounded-2xl border border-primary/15 bg-gradient-to-br from-primary/5 via-white to-secondary/5 p-7 shadow-sm transition-all duration-300 hover:shadow-xl">
              <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-primary to-secondary"></div>
              <div class="pointer-events-none absolute right-0 top-0 h-28 w-28 text-primary/[0.06] gfx-grid"></div>
              <div class="relative">
                <div class="mb-4 flex items-center gap-4">
                  <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-primary to-secondary text-white shadow-md">
                    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                  </div>
                  <h3 class="text-lg font-bold text-gray-900">{t('about.story.backing.title')}</h3>
                </div>
                <p class="leading-relaxed text-gray-600">{t('about.story.backing.desc')}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Mission Section -->
    <section class="relative overflow-hidden bg-primary/5 py-20">
      <!-- Trust/partnership backdrop (real-world, subtle parallax) -->
      <img src="/images/gcc/handshake.webp" alt="Two businesspeople shaking hands — partnership and trust" loading="lazy" decoding="async" data-parallax="0.07" class="parallax-media opacity-[0.16]" />
      <div class="pointer-events-none absolute inset-0 bg-white/45"></div>
      <div class="relative z-10 max-w-7xl mx-auto px-4">
        <div class="grid gap-12 lg:grid-cols-2 items-center max-w-6xl mx-auto">
          <div>
            <span class="inline-flex items-center mb-4 px-3 py-1 border border-gray-300 text-gray-600 rounded-md text-sm font-medium">
              {t('about.mission.badge')}
            </span>
            <h2 class="text-3xl md:text-4xl font-bold mb-6 text-gray-900">
              {t('about.mission.title')}
            </h2>
            <p class="text-gray-500 mb-6 text-lg">
              {t('about.mission.desc')}
            </p>
            <div class="space-y-3">
              <div class="flex items-center gap-3">
                <svg class="h-5 w-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-gray-700">{t('about.mission.vetting')}</span>
              </div>
              <div class="flex items-center gap-3">
                <svg class="h-5 w-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-gray-700">{t('about.mission.local')}</span>
              </div>
              <div class="flex items-center gap-3">
                <svg class="h-5 w-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-gray-700">{t('about.mission.secure')}</span>
              </div>
              <div class="flex items-center gap-3">
                <svg class="h-5 w-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-gray-700">{t('about.mission.growth')}</span>
              </div>
            </div>
          </div>
          <div class="reveal relative">
            <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-primary to-secondary p-8 text-white shadow-xl lg:p-10">
              <div class="pointer-events-none absolute inset-0 text-white/[0.08] gfx-grid"></div>
              <div class="pointer-events-none absolute -top-12 -right-12 h-44 w-44 rounded-full bg-white/10 blur-3xl"></div>
              <div class="pointer-events-none absolute -bottom-12 -left-12 h-44 w-44 rounded-full bg-accent/20 blur-3xl"></div>
              <div class="relative">
                <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-white/15 ring-1 ring-white/20 backdrop-blur">
                  <svg class="h-9 w-9" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
                </div>
                <p class="mb-2 text-xs font-bold uppercase tracking-wider text-white/70">{t('about.mission.pledge.title')}</p>
                <p class="text-2xl font-bold leading-snug">{t('about.mission.pledge.desc')}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- GCC Presence Section (real-world city imagery from across the Gulf) -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-12 reveal">
          <span class="inline-flex items-center mb-4 px-3 py-1 border border-gray-300 text-gray-600 rounded-md text-sm font-medium">
            {t('about.gcc.badge')}
          </span>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 text-gray-900">
            {t('about.gcc.title')}
          </h2>
          <p class="mx-auto max-w-3xl text-xl text-gray-500">
            {t('about.gcc.desc')}
          </p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 gap-4 sm:gap-5 max-w-5xl mx-auto">
          {gccPlaces.map((place, i) => (
            <div class={`reveal ${i % 3 === 1 ? 'reveal-d1' : i % 3 === 2 ? 'reveal-d2' : ''} group relative aspect-[4/3] overflow-hidden rounded-2xl shadow-sm ring-1 ring-gray-200/70`}>
              <img
                src={`/images/gcc/${place.img}.webp`}
                alt={`${place.name} — city skyline`}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/15 to-transparent"></div>
              <div class="absolute top-3 end-3">
                <span class={`inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-[11px] font-semibold text-white backdrop-blur ${place.live ? 'bg-emerald-500/90' : 'bg-white/20 ring-1 ring-white/30'}`}>
                  {place.live && (
                    <span class="relative flex h-1.5 w-1.5">
                      <span class="absolute inline-flex h-full w-full rounded-full bg-white opacity-75 motion-safe:animate-ping"></span>
                      <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-white"></span>
                    </span>
                  )}
                  {place.live ? t('about.gcc.live') : t('about.gcc.soon')}
                </span>
              </div>
              <div class="absolute inset-x-0 bottom-0 p-4 text-start">
                <p class="text-base font-bold leading-tight text-white drop-shadow">{place.name}</p>
              </div>
              <!-- Hover overlay: how Oyifa aligns with private-sector IT procurement in this market -->
              <div class="absolute inset-0 flex flex-col justify-end gap-1.5 bg-gradient-to-t from-[#271060]/80 via-primary/50 to-primary/15 p-4 text-start opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                <p class="text-base font-bold leading-tight text-white drop-shadow">{place.name}</p>
                <p class="text-xs leading-relaxed text-white/90">{place.blurb}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Values Section -->
    <section class="relative overflow-hidden py-20 bg-white">
      <!-- Team collaboration backdrop (real-world, subtle parallax) -->
      <img src="/images/gcc/collaboration.webp" alt="Diverse IT team collaborating around laptops in a modern office" loading="lazy" decoding="async" data-parallax="0.08" class="parallax-media opacity-[0.12]" />
      <div class="pointer-events-none absolute inset-0 bg-white/55"></div>
      <div class="relative z-10 max-w-7xl mx-auto px-4">
        <div class="text-center mb-12">
          <span class="inline-flex items-center mb-4 px-3 py-1 border border-gray-300 text-gray-600 rounded-md text-sm font-medium">
            {t('about.values.badge')}
          </span>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 text-gray-900">
            {t('about.values.title')}
          </h2>
          <p class="mx-auto max-w-3xl text-xl text-gray-500">
            {t('about.values.desc')}
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4 max-w-6xl mx-auto items-stretch">
          <!-- Transparency -->
          <div class="reveal reveal-d1 group relative flex h-full flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white p-6 text-center shadow-sm transition-all duration-300 hover:shadow-xl">
            <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-primary to-secondary"></div>
            <div class="pointer-events-none absolute right-0 top-0 h-20 w-20 text-primary/[0.06] gfx-dots" style="-webkit-mask-image:linear-gradient(225deg,#000,transparent);mask-image:linear-gradient(225deg,#000,transparent)"></div>
            <div class="relative mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-primary to-secondary text-white shadow-md">
              <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
            </div>
            <h3 class="relative text-lg font-bold mb-2 text-gray-900">{t('about.values.honesty.title')}</h3>
            <p class="relative flex-1 text-sm leading-relaxed text-gray-500">{t('about.values.honesty.desc')}</p>
          </div>

          <!-- Simplicity -->
          <div class="reveal reveal-d2 group relative flex h-full flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white p-6 text-center shadow-sm transition-all duration-300 hover:shadow-xl">
            <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-secondary to-accent"></div>
            <div class="pointer-events-none absolute right-0 top-0 h-20 w-20 text-secondary/[0.06] gfx-dots" style="-webkit-mask-image:linear-gradient(225deg,#000,transparent);mask-image:linear-gradient(225deg,#000,transparent)"></div>
            <div class="relative mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-secondary to-accent text-white shadow-md">
              <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <h3 class="relative text-lg font-bold mb-2 text-gray-900">{t('about.values.simplicity.title')}</h3>
            <p class="relative flex-1 text-sm leading-relaxed text-gray-500">{t('about.values.simplicity.desc')}</p>
          </div>

          <!-- Regional Strength -->
          <div class="reveal reveal-d3 group relative flex h-full flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white p-6 text-center shadow-sm transition-all duration-300 hover:shadow-xl">
            <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-accent to-primary"></div>
            <div class="pointer-events-none absolute right-0 top-0 h-20 w-20 text-accent/[0.06] gfx-dots" style="-webkit-mask-image:linear-gradient(225deg,#000,transparent);mask-image:linear-gradient(225deg,#000,transparent)"></div>
            <div class="relative mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-accent to-primary text-white shadow-md">
              <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="relative text-lg font-bold mb-2 text-gray-900">{t('about.values.regional.title')}</h3>
            <p class="relative flex-1 text-sm leading-relaxed text-gray-500">{t('about.values.regional.desc')}</p>
          </div>

          <!-- Client Integrity -->
          <div class="reveal reveal-d3 group relative flex h-full flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white p-6 text-center shadow-sm transition-all duration-300 hover:shadow-xl">
            <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-primary to-accent"></div>
            <div class="pointer-events-none absolute right-0 top-0 h-20 w-20 text-primary/[0.06] gfx-dots" style="-webkit-mask-image:linear-gradient(225deg,#000,transparent);mask-image:linear-gradient(225deg,#000,transparent)"></div>
            <div class="relative mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-primary to-accent text-white shadow-md">
              <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <h3 class="relative text-lg font-bold mb-2 text-gray-900">{t('about.values.integrity.title')}</h3>
            <p class="relative flex-1 text-sm leading-relaxed text-gray-500">{t('about.values.integrity.desc')}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Team Section -->
    <section class="bg-purple-50/50 py-20">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-12">
          <span class="inline-flex items-center mb-4 px-3 py-1 border border-gray-300 text-gray-600 rounded-md text-sm font-medium">
            {t('about.team.badge')}
          </span>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 text-gray-900">
            {t('about.team.title')}
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto items-stretch">
          <!-- Regional Expertise -->
          <div class="reveal reveal-d1 group relative flex h-full flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white p-7 shadow-sm transition-all duration-300 hover:shadow-xl">
            <img src="/images/gcc/meeting.webp" alt="Business team reviewing IT proposals in a meeting" loading="lazy" decoding="async" class="absolute inset-0 h-full w-full object-cover opacity-[0.14] transition-opacity duration-500 group-hover:opacity-[0.22]" />
            <div class="pointer-events-none absolute inset-0 bg-white/45"></div>
            <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-primary to-secondary"></div>
            <div class="pointer-events-none absolute -right-8 -top-8 h-24 w-24 rounded-full bg-primary/5 blur-2xl"></div>
            <div class="relative mb-4 flex items-center gap-4">
              <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900">{t('about.team.regional.title')}</h3>
            </div>
            <p class="relative flex-1 leading-relaxed text-gray-600">{t('about.team.regional.desc')}</p>
