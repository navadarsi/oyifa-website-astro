            <div class="pointer-events-none absolute inset-0 bg-white/45"></div>
            <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-accent to-secondary"></div>
            <div class="pointer-events-none absolute -right-8 -top-8 h-24 w-24 rounded-full bg-accent/5 blur-2xl"></div>
            <div class="relative mb-4 flex items-center gap-4">
              <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-accent/10 text-accent">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900">{t('about.team.global.title')}</h3>
            </div>
            <p class="relative flex-1 leading-relaxed text-gray-600">{t('about.team.global.desc')}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="relative overflow-hidden py-20 bg-white">
      <!-- Team unity backdrop (real-world, subtle parallax) -->
      <img src="/images/gcc/community.webp" alt="Diverse team putting their hands together in unity" loading="lazy" decoding="async" data-parallax="0.1" class="parallax-media opacity-[0.14]" />
      <div class="pointer-events-none absolute inset-0 bg-white/60"></div>
      <div class="relative z-10 max-w-7xl mx-auto px-4 text-center">
        <span class="inline-flex items-center mb-6 px-3 py-1 bg-purple-100 text-primary rounded-md text-sm font-medium">
          {t('about.cta.badge')}
        </span>
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-gray-900">
          {t('about.cta.title')}
        </h2>
        <p class="mx-auto mb-8 max-w-3xl text-xl text-gray-500">
          {t('about.cta.desc')}
        </p>

        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href={`${URLS.app}/register`} class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary text-white font-medium rounded-md hover:bg-primary/90 transition-colors">
