---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/utils';
import { URLS } from '../../config/urls';

const t = useTranslations('ar');
---

<BaseLayout
  title={t('contact.meta.title')}
  description={t('contact.meta.desc')}
  lang="ar"
>
  <Header />

  <main class="flex-1" dir="rtl">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-primary/10 via-white to-purple-50/50 py-32">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <span class="inline-block mb-4 px-3 py-1 bg-purple-100 text-primary rounded-full text-sm font-medium">
          {t('contact.hero.badge')}
        </span>
        <h1 class="mb-6 text-5xl font-extrabold tracking-tight md:text-6xl text-gray-900">
          {t('contact.hero.title.part1')}{" "}
          <span class="text-primary">{t('contact.hero.title.highlight')}</span>
        </h1>
        <p class="mx-auto mb-8 max-w-3xl text-xl text-gray-500">
          {t('contact.hero.desc')}
        </p>
        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <button
            onclick="document.getElementById('contact-form')?.scrollIntoView({ behavior: 'smooth' })"
            class="inline-flex items-center gap-2 bg-primary text-white px-6 py-3 rounded-md text-base font-medium hover:bg-primary-light transition-colors"
          >
            {t('contact.hero.start')}
            <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </button>
          <a href="/ar/pricing" class="inline-flex items-center justify-center bg-white text-gray-900 border border-gray-300 px-6 py-3 rounded-md text-base font-medium hover:bg-gray-50 transition-colors">
            {t('contact.hero.pricing')}
          </a>
        </div>
      </div>
    </section>

    <!-- Contact Methods Section -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-12">
          <span class="inline-block mb-4 px-3 py-1 border border-gray-300 text-gray-600 rounded-full text-sm font-medium">
            {t('contact.methods.badge')}
          </span>
          <h2 class="text-3xl font-bold mb-6 md:text-4xl text-gray-900">
            {t('contact.methods.title')}
          </h2>
          <p class="mx-auto max-w-2xl text-xl text-gray-500">
            {t('contact.methods.desc')}
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 max-w-4xl mx-auto items-start">
          <!-- Email Support -->
          <a href="mailto:info@oyifa.com" class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white p-7 text-start shadow-sm transition-all duration-300 hover:-translate-y-1.5 hover:border-primary/30 hover:shadow-xl">
            <div class="pointer-events-none absolute -right-10 -top-10 h-28 w-28 rounded-full bg-primary/5 blur-2xl"></div>
            <div class="pointer-events-none absolute right-0 top-0 h-24 w-24 text-primary/[0.06] gfx-dots" style="-webkit-mask-image:linear-gradient(225deg,#000,transparent);mask-image:linear-gradient(225deg,#000,transparent)"></div>
            <div class="relative flex items-center gap-4">
              <div class="inline-flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-primary to-secondary text-white shadow-md transition-transform duration-300 group-hover:scale-110">
                <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-gray-900">{t('contact.methods.email.title')}</h3>
                <p class="text-sm text-gray-500">{t('contact.methods.email.desc')}</p>
              </div>
            </div>
            <div class="relative mt-6 flex items-center justify-between rounded-xl bg-gray-50 px-4 py-3 ring-1 ring-gray-100 transition-colors duration-300 group-hover:bg-primary/5">
              <span class="font-semibold text-gray-900" dir="ltr">info@oyifa.com</span>
              <span class="inline-flex items-center gap-1 text-sm font-semibold text-primary">
                {t('contact.methods.email.action')}
                <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1 rtl:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
              </span>
            </div>
          </a>

          <!-- Phone Support -->
          <a href="tel:+971524767569" class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white p-7 text-start shadow-sm transition-all duration-300 hover:-translate-y-1.5 hover:border-accent/30 hover:shadow-xl">
            <div class="pointer-events-none absolute -right-10 -top-10 h-28 w-28 rounded-full bg-accent/5 blur-2xl"></div>
            <div class="pointer-events-none absolute right-0 top-0 h-24 w-24 text-accent/[0.06] gfx-dots" style="-webkit-mask-image:linear-gradient(225deg,#000,transparent);mask-image:linear-gradient(225deg,#000,transparent)"></div>
            <div class="relative flex items-center gap-4">
              <div class="inline-flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-accent to-secondary text-white shadow-md transition-transform duration-300 group-hover:scale-110">
                <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-gray-900">{t('contact.methods.phone.title')}</h3>
                <p class="text-sm text-gray-500">{t('contact.methods.phone.desc')}</p>
              </div>
            </div>
            <div class="relative mt-6 rounded-xl bg-gray-50 px-4 py-3 ring-1 ring-gray-100 transition-colors duration-300 group-hover:bg-accent/5">
              <div class="flex items-center justify-between">
                <span class="font-semibold text-gray-900" dir="ltr">+971 52 476 7569</span>
                <span class="inline-flex items-center gap-1 text-sm font-semibold text-accent">
                  {t('contact.methods.phone.action')}
                  <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1 rtl:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                </span>
              </div>
              <p class="mt-1.5 flex items-center gap-1.5 text-xs text-gray-500">
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                {t('contact.methods.phone.hours')}
              </p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Contact Form & Schedule a Demo (Side by Side) -->
    <section id="contact-form" class="py-20 bg-primary/5">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-12">
          <span class="inline-block mb-4 px-3 py-1 border border-gray-300 text-gray-600 rounded-full text-sm font-medium">
            {t('contact.form.badge')}
          </span>
          <h2 class="text-3xl font-bold mb-6 md:text-4xl text-gray-900">
            {t('contact.form.title')}
          </h2>
          <p class="mx-auto max-w-2xl text-xl text-gray-500">
            {t('contact.form.desc')}
          </p>
        </div>

        <div class="grid lg:grid-cols-2 gap-8 items-start">
          <!-- Contact Form -->
          <div class="bg-white rounded-lg border border-gray-200 shadow-sm">
            <div class="p-6 border-b border-gray-200">
              <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                {t('contact.form.send')}
              </h3>
            </div>
            <div class="p-6">
              <form id="contactForm" class="space-y-4">
                <div class="grid sm:grid-cols-2 gap-4">
                  <div class="space-y-2">
                    <label for="name" class="block text-sm font-medium text-gray-700">
                      {t('contact.form.name')} *
                    </label>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      required
                      placeholder={t('contact.form.name_placeholder')}
                      class="flex h-10 w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 transition-colors"
                    />
                  </div>
                  <div class="space-y-2">
                    <label for="email" class="block text-sm font-medium text-gray-700">
                      {t('contact.form.email')} *
                    </label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      dir="ltr"
                      placeholder={t('contact.form.email_placeholder')}
                      class="flex h-10 w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 transition-colors text-left"
                    />
                  </div>
                </div>

                <div class="grid sm:grid-cols-2 gap-4">
                  <div class="space-y-2">
                    <label for="company" class="block text-sm font-medium text-gray-700">
                      {t('contact.form.company')}
                    </label>
                    <input
                      type="text"
                      id="company"
                      name="company"
                      placeholder={t('contact.form.company_placeholder')}
                      class="flex h-10 w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 transition-colors"
                    />
                  </div>
                  <div class="space-y-2">
                    <label for="role" class="block text-sm font-medium text-gray-700">
                      {t('contact.form.role')}
                    </label>
                    <select
                      id="role"
                      name="role"
                      class="flex h-10 w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 transition-colors"
                    >
                      <option value="">{t('contact.form.role_select')}</option>
                      <option value="ceo">{t('contact.form.role.ceo')}</option>
                      <option value="cto">{t('contact.form.role.cto')}</option>
                      <option value="it">{t('contact.form.role.it')}</option>
                      <option value="procurement">{t('contact.form.role.procurement')}</option>
                      <option value="vendor">{t('contact.form.role.vendor')}</option>
                      <option value="other">{t('contact.form.role.other')}</option>
                    </select>
                  </div>
                </div>

                <div class="space-y-2">
                  <label for="subject" class="block text-sm font-medium text-gray-700">
                    {t('contact.form.subject')}
                  </label>
                  <input
                    type="text"
                    id="subject"
                    name="subject"
                    placeholder={t('contact.form.subject_placeholder')}
                    class="flex h-10 w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 transition-colors"
                  />
                </div>

                <div class="space-y-2">
                  <label for="message" class="block text-sm font-medium text-gray-700">
                    {t('contact.form.message')} *
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    rows="4"
                    required
                    placeholder={t('contact.form.message_placeholder')}
                    class="flex min-h-[120px] w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 transition-colors resize-none"
                  ></textarea>
                </div>

                <button
                  type="submit"
                  class="w-full inline-flex items-center justify-center gap-2 bg-primary text-white px-6 py-3 rounded-md text-base font-medium hover:bg-primary-light transition-colors"
                >
                  <span id="submitText">{t('contact.form.send')}</span>
                  <svg class="w-4 h-4 rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                  </svg>
                </button>
              </form>

              <!-- Success Message -->
              <div id="successMessage" class="hidden text-center py-8">
                <div class="mb-4 text-green-500">
                  <svg class="w-16 h-16 mx-auto" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">{t('contact.form.success.title')}</h3>
                <p class="text-gray-500 mb-6">{t('contact.form.success.desc')}</p>
                <button type="button" id="resetForm" class="inline-flex items-center justify-center bg-white text-gray-900 border border-gray-300 px-4 py-2 rounded-md text-sm font-medium hover:bg-gray-50 transition-colors">
                  {t('contact.form.another')}
                </button>
              </div>
            </div>
          </div>

          <!-- Schedule a Demo -->
          <div class="bg-white rounded-lg border border-gray-200 shadow-sm">
            <div class="p-6 border-b border-gray-200">
              <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                احجز عرضًا توضيحيًا
              </h3>
            </div>
            <div class="calendly-inline-widget" data-url="https://calendly.com/oyifa/discovery-call" style="min-width:320px;height:660px;"></div>
            <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-primary/5">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-6 md:text-4xl text-gray-900">
          {t('contact.cta.title')}
        </h2>
        <p class="mx-auto mb-8 max-w-2xl text-xl text-gray-500">
          {t('contact.cta.desc')}
        </p>
        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href={`${URLS.app}/register`} class="inline-flex items-center gap-2 bg-primary text-white px-6 py-3 rounded-md text-base font-medium hover:bg-primary-light transition-colors">
            {t('contact.cta.start')}
            <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
          <a href="/ar/about" class="inline-flex items-center justify-center bg-white text-gray-900 border border-gray-300 px-6 py-3 rounded-md text-base font-medium hover:bg-gray-50 transition-colors">
            {t('contact.cta.learn')}
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const successMessage = document.getElementById('successMessage');
  const submitText = document.getElementById('submitText');
  const resetFormBtn = document.getElementById('resetForm');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (submitText) {
      submitText.textContent = 'جاري الإرسال...';
    }

    // Simulate form submission
    await new Promise(resolve => setTimeout(resolve, 1000));

    // Show success message
    form.classList.add('hidden');
    successMessage?.classList.remove('hidden');
  });

  resetFormBtn?.addEventListener('click', () => {
    form.reset();
    form.classList.remove('hidden');
    successMessage?.classList.add('hidden');
    if (submitText) {
      submitText.textContent = 'إرسال الرسالة';
    }
  });
</script>

