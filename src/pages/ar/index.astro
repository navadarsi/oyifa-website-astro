---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import GccMap from '../../components/GccMap.astro';
import HeroGraphics from '../../components/HeroGraphics.astro';
import { useTranslations } from '../../i18n/utils';
import { URLS } from '../../config/urls';

const t = useTranslations('ar');
---

<BaseLayout
  title={t('index.hero.title.highlight')}
  description={t('index.hero.subtitle')}
  lang="ar"
  schemaType="homepage"
>
  <Header />

  <main class="flex-1" dir="rtl">
    <!-- Section 1: Hero - Introducing Oyifa Movement -->
    <section class="relative overflow-hidden bg-gradient-to-br from-primary/5 via-white to-secondary/5 py-16 md:py-24 lg:py-32">
      <!-- Background decorative elements -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="hidden lg:block absolute -top-40 -left-40 h-80 w-80 rounded-full bg-primary/10 blur-3xl"></div>
        <div class="hidden lg:block absolute -bottom-40 -right-40 h-80 w-80 rounded-full bg-secondary/10 blur-3xl"></div>
        <!-- GCC map watermark: only graphic on mobile; start (content) side on desktop -->
        <div class="absolute start-0 end-0 top-1/2 bottom-0 flex items-center justify-center lg:top-0 lg:end-auto lg:w-1/2 lg:justify-start opacity-[0.2]">
          <GccMap class="w-[72%] max-w-xs sm:max-w-sm lg:w-[86%] lg:max-w-lg lg:ms-[4%]" />
        </div>
        <!-- Accent graphics (desktop), sit behind the video -->
        <HeroGraphics class="hidden lg:block absolute top-1/2 end-0 -translate-y-1/2 me-[-4%] w-[42%] max-w-xl opacity-70" />
      </div>

      <div class="container relative mx-auto px-4 max-w-7xl">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <!-- Right side - Content (appears first in RTL) -->
          <div class="order-2 lg:order-1 text-center lg:text-start">
            <!-- Golden certification seal: Gulf's First Private IT Tender Board (kept in normal flow so it sits correctly on every viewport) -->
            <div class="mb-4 flex justify-center lg:justify-start">
              <span class="badge-gold badge-shimmer inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-[11px] sm:text-xs font-extrabold tracking-wide ring-1 ring-amber-300/50">
                <svg class="h-4 w-4 flex-shrink-0 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                {t('index.hero.gulf_badge')}
              </span>
            </div>
            <span class="inline-flex mb-6 px-4 py-2 bg-secondary/10 text-primary rounded-full text-sm font-medium">
              {t('index.hero.badge')}
            </span>

            <h1 class="mb-6 text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl text-gray-900">
              {t('index.hero.title.part1')}{" "}
              <span class="text-primary">
                {t('index.hero.title.highlight')}
              </span>
            </h1>

            <p class="mb-6 text-lg sm:text-xl text-gray-600 max-w-xl mx-auto lg:mx-0">
              {t('index.hero.subtitle')}
            </p>

            <div class="mb-8 space-y-3 text-base text-gray-500 max-w-xl mx-auto lg:mx-0">
              <p class="flex items-start gap-2 justify-center lg:justify-start">
                <span class="text-primary mt-1">&#10022;</span>
                {t('index.hero.inspiration')}
              </p>
              <p class="flex items-start gap-2 justify-center lg:justify-start">
                <span class="text-primary mt-1">&#10022;</span>
                {t('index.hero.mission')}
              </p>
            </div>

            <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
              <a href={`${URLS.app}/register/client`} class="btn btn-primary btn-lg shadow-lg hover:shadow-xl transition-all">
                {t('index.hero.cta.client')}
                <svg class="w-5 h-5 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </a>
              <a href={`${URLS.app}/register/vendor`} class="btn btn-outline btn-lg hover:bg-secondary/10 transition-all">
                {t('index.hero.cta.vendor')}
              </a>
            </div>
          </div>

          <!-- Left side - Video (appears second in RTL) -->
          <div class="order-1 lg:order-2">
            <div class="relative">
              <!-- Video container with decorative frame -->
              <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-gray-200/50 bg-white">
                <!-- Decorative corner accents -->
                <div class="absolute top-0 right-0 w-20 h-20 border-r-4 border-t-4 border-primary/30 rounded-tr-2xl translate-x-2 -translate-y-2 pointer-events-none"></div>
                <div class="absolute bottom-0 left-0 w-20 h-20 border-l-4 border-b-4 border-primary/30 rounded-bl-2xl -translate-x-2 translate-y-2 pointer-events-none"></div>

                <!-- YouTube Video (lite-youtube-embed: loads iframe only on click) -->
                <div class="aspect-video bg-gradient-to-br from-primary/5 to-secondary/5">
                  <lite-youtube
                    videoid="PBEse58Fz7s"
                    playlabel="شاهد عرض أويفا التوضيحي"
                    style="background-image: url('https://i.ytimg.com/vi/PBEse58Fz7s/hqdefault.jpg');"
                  >
                    <button type="button" class="lty-playbtn">
                      <span class="lyt-visually-hidden">تشغيل الفيديو</span>
                    </button>
                  </lite-youtube>
                </div>
              </div>

              <!-- Floating stats card -->
              <div class="absolute -bottom-6 -right-6 bg-white rounded-xl shadow-lg border border-gray-200/50 p-4 hidden sm:block">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
                    <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold text-gray-900">منصة المناقصات الموثوقة</p>
                    <p class="text-sm text-gray-500">مصممة لدول الخليج</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: The Problem - Broken IT Procurement Process -->
    <section class="py-20 bg-white">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="text-center mb-16">
          <span class="inline-block mb-4 px-4 py-2 border border-gray-300 text-gray-600 rounded-full text-sm font-medium">
            {t('index.problem.badge')}
          </span>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 text-gray-900">
            {t('index.problem.title')}
          </h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            {t('index.problem.subtitle')}
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
          <!-- 01 -->
          <div class="reveal reveal-d1 group relative overflow-hidden rounded-2xl border border-gray-200 bg-white p-7 text-start shadow-sm transition-all duration-300 hover:-translate-y-1.5 hover:border-rose-200 hover:shadow-xl">
            <span class="pointer-events-none absolute right-3 top-0 select-none text-7xl font-black leading-none text-rose-500/10">01</span>
            <div class="pointer-events-none absolute right-0 top-0 h-24 w-24 text-rose-500/20 gfx-diag" style="-webkit-mask-image:linear-gradient(225deg,#000,transparent);mask-image:linear-gradient(225deg,#000,transparent)"></div>
            <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-rose-400 to-red-500 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
            <div class="relative">
              <div class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-rose-50 ring-1 ring-inset ring-rose-100 transition-transform duration-300 group-hover:-rotate-6">
                <svg class="w-7 h-7 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold mb-2 text-gray-900">{t('index.problem.sales.title')}</h3>
              <p class="text-gray-600 leading-relaxed">{t('index.problem.sales.desc')}</p>
            </div>
          </div>

          <!-- 02 -->
          <div class="reveal reveal-d2 group relative overflow-hidden rounded-2xl border border-gray-200 bg-white p-7 text-start shadow-sm transition-all duration-300 hover:-translate-y-1.5 hover:border-rose-200 hover:shadow-xl">
            <span class="pointer-events-none absolute right-3 top-0 select-none text-7xl font-black leading-none text-rose-500/10">02</span>
            <div class="pointer-events-none absolute right-0 top-0 h-24 w-24 text-rose-500/20 gfx-diag" style="-webkit-mask-image:linear-gradient(225deg,#000,transparent);mask-image:linear-gradient(225deg,#000,transparent)"></div>
            <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-rose-400 to-red-500 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
            <div class="relative">
              <div class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-rose-50 ring-1 ring-inset ring-rose-100 transition-transform duration-300 group-hover:-rotate-6">
                <svg class="w-7 h-7 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold mb-2 text-gray-900">{t('index.problem.pitches.title')}</h3>
              <p class="text-gray-600 leading-relaxed">{t('index.problem.pitches.desc')}</p>
            </div>
          </div>

          <!-- 03 -->
          <div class="reveal reveal-d3 group relative overflow-hidden rounded-2xl border border-gray-200 bg-white p-7 text-start shadow-sm transition-all duration-300 hover:-translate-y-1.5 hover:border-rose-200 hover:shadow-xl">
            <span class="pointer-events-none absolute right-3 top-0 select-none text-7xl font-black leading-none text-rose-500/10">03</span>
            <div class="pointer-events-none absolute right-0 top-0 h-24 w-24 text-rose-500/20 gfx-diag" style="-webkit-mask-image:linear-gradient(225deg,#000,transparent);mask-image:linear-gradient(225deg,#000,transparent)"></div>
            <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-rose-400 to-red-500 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
            <div class="relative">
              <div class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-rose-50 ring-1 ring-inset ring-rose-100 transition-transform duration-300 group-hover:-rotate-6">
                <svg class="w-7 h-7 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold mb-2 text-gray-900">{t('index.problem.pressure.title')}</h3>
              <p class="text-gray-600 leading-relaxed">{t('index.problem.pressure.desc')}</p>
            </div>
          </div>
        </div>

        <div class="text-center mt-12">
          <p class="text-lg font-medium text-primary">
            {t('index.problem.conclusion')}
          </p>
        </div>
      </div>
    </section>

    <!-- Section 3: The Solution - How Oyifa Fixes This -->
    <section class="relative overflow-hidden bg-primary/5 py-20">
      <!-- Subtle real-world backdrop behind the solution cards -->
      <img src="/images/gcc/team.jpg" alt="" aria-hidden="true" loading="lazy" decoding="async" data-parallax="0.06" class="parallax-media opacity-[0.07]" />
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-primary/[0.04] via-white/30 to-primary/[0.04]"></div>
      <div class="container relative z-10 mx-auto px-4 max-w-7xl">
        <div class="text-center mb-16">
          <span class="inline-block mb-4 px-4 py-2 border border-gray-300 text-gray-600 rounded-full text-sm font-medium">
            {t('index.solution.badge')}
          </span>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 text-gray-900">
            {t('index.solution.title')}
          </h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            {t('index.solution.subtitle')}
          </p>
        </div>

        <div class="grid lg:grid-cols-2 gap-10 lg:gap-12 items-center max-w-6xl mx-auto">
          <div class="space-y-5">
            <!-- Rigorous Vetting -->
            <div class="reveal reveal-d1 group relative flex items-start gap-4 overflow-hidden rounded-xl border border-primary/10 bg-white p-5 ps-7 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md">
              <span class="absolute start-0 top-4 bottom-4 w-1.5 rounded-full bg-gradient-to-b from-primary to-secondary"></span>
              <div class="inline-flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary transition-transform duration-300 group-hover:scale-110">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold mb-1 text-gray-900">{t('index.solution.vetting.title')}</h3>
                <p class="text-gray-600 text-sm leading-relaxed">{t('index.solution.vetting.desc')}</p>
              </div>
            </div>

            <!-- Prioritizing Local Talent -->
            <div class="reveal reveal-d2 group relative flex items-start gap-4 overflow-hidden rounded-xl border border-primary/10 bg-white p-5 ps-7 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md">
              <span class="absolute start-0 top-4 bottom-4 w-1.5 rounded-full bg-gradient-to-b from-secondary to-accent"></span>
              <div class="inline-flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-secondary/10 text-secondary transition-transform duration-300 group-hover:scale-110">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold mb-1 text-gray-900">{t('index.solution.local.title')}</h3>
                <p class="text-gray-600 text-sm leading-relaxed">{t('index.solution.local.desc')}</p>
              </div>
            </div>

            <!-- Client-Controlled Contact -->
            <div class="reveal reveal-d3 group relative flex items-start gap-4 overflow-hidden rounded-xl border border-primary/10 bg-white p-5 ps-7 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md">
              <span class="absolute start-0 top-4 bottom-4 w-1.5 rounded-full bg-gradient-to-b from-accent to-primary"></span>
              <div class="inline-flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-accent/10 text-accent transition-transform duration-300 group-hover:scale-110">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold mb-1 text-gray-900">{t('index.solution.secure.title')}</h3>
                <p class="text-gray-600 text-sm leading-relaxed">{t('index.solution.secure.desc')}</p>
              </div>
            </div>
          </div>

          <!-- How Oyifa works (3 honest steps) -->
          <div class="reveal relative mx-auto w-full max-w-md">
            <div class="relative overflow-hidden rounded-3xl border border-primary/10 bg-white p-6 shadow-lg sm:p-8">
              <div class="pointer-events-none absolute inset-0 text-primary/[0.05] gfx-grid"></div>
              <div class="relative text-start">
                <p class="text-xs font-bold uppercase tracking-wider text-primary">كيف تعمل أويفا</p>
                <p class="mb-6 mt-1 text-sm text-gray-500">انشر مرة واحدة. يردّ موردون موثّقون. أنت تختار.</p>

                <ol class="relative space-y-5">
                  <span class="absolute start-5 top-4 bottom-4 w-px bg-gradient-to-b from-primary/30 via-secondary/30 to-accent/30"></span>

                  <li class="relative flex items-start gap-4">
                    <span class="z-10 flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-white shadow-md ring-4 ring-white">1</span>
                    <div class="pt-1.5">
                      <p class="text-sm font-semibold text-gray-900">انشر متطلبك</p>
                      <p class="text-xs text-gray-500">مجاناً وفي دقائق. العملاء لا يدفعون لأويفا أبداً.</p>
                    </div>
                  </li>
                  <li class="relative flex items-start gap-4">
                    <span class="z-10 flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-secondary text-sm font-bold text-white shadow-md ring-4 ring-white">2</span>
                    <div class="pt-1.5">
                      <p class="text-sm font-semibold text-gray-900">يردّ موردون موثّقون</p>
                      <p class="text-xs text-gray-500">موردون مفحوصون بالرخصة والتنفيذ والمراجع فقط.</p>
                    </div>
                  </li>
                  <li class="relative flex items-start gap-4">
                    <span class="z-10 flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-accent text-sm font-bold text-white shadow-md ring-4 ring-white">3</span>
                    <div class="pt-1.5">
                      <p class="text-sm font-semibold text-gray-900">تقارن وتختار</p>
                      <p class="text-xs text-gray-500">هويتك تبقى خاصة حتى تتواصل.</p>
                    </div>
                  </li>
                </ol>

                <!-- Commitment footer -->
                <div class="mt-7 flex items-start gap-3 rounded-2xl bg-gradient-to-br from-primary to-secondary p-4 text-white">
                  <svg class="mt-0.5 h-6 w-6 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                  <div>
                    <p class="text-sm font-bold">{t('index.solution.commitment.title')}</p>
                    <p class="text-xs text-white/80">{t('index.solution.commitment.desc')}</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 4: Our Values - Regional Strength, Honesty, Simplicity -->
    <section class="py-20 bg-white">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="text-center mb-16">
          <span class="inline-block mb-4 px-4 py-2 border border-gray-300 text-gray-600 rounded-full text-sm font-medium">
            {t('index.values.badge')}
          </span>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 text-gray-900">
            {t('index.values.title')}
          </h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto mb-8">
            {t('index.values.subtitle')}
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto items-stretch">
          <!-- Verified Status -->
          <div class="reveal reveal-d1 group relative flex h-full flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white p-7 text-start shadow-sm transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl">
            <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-primary to-secondary"></div>
            <div class="pointer-events-none absolute -right-10 -top-10 h-28 w-28 rounded-full bg-primary/5 blur-2xl"></div>
            <div class="relative flex items-center justify-between">
              <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary transition-transform duration-300 group-hover:scale-110">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
              </div>
              <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-bold text-emerald-700 ring-1 ring-emerald-100">
