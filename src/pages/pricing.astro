---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PricingSchema from '../components/PricingSchema.astro';
import { useTranslations } from '../i18n/utils';
import { URLS } from '../config/urls';

const t = useTranslations('en');

// GCC Country pricing data
const gccCountries = [
  { code: 'AE', name: 'United Arab Emirates', currency: 'AED', symbol: 'AED' },
  { code: 'SA', name: 'Saudi Arabia', currency: 'SAR', symbol: 'SAR' },
  { code: 'QA', name: 'Qatar', currency: 'QAR', symbol: 'QAR' },
  { code: 'KW', name: 'Kuwait', currency: 'KWD', symbol: 'KWD' },
  { code: 'BH', name: 'Bahrain', currency: 'BHD', symbol: 'BHD' },
  { code: 'OM', name: 'Oman', currency: 'OMR', symbol: 'OMR' },
];

// Pricing by currency (monthly and yearly)
const pricing = {
  AED: { free: { monthly: 0, yearly: 0 }, basic: { monthly: 499, yearly: 4999 }, standard: { monthly: 999, yearly: 9999 }, premium: { monthly: 1499, yearly: 14999 } },
  SAR: { free: { monthly: 0, yearly: 0 }, basic: { monthly: 499, yearly: 4999 }, standard: { monthly: 999, yearly: 9999 }, premium: { monthly: 1499, yearly: 14999 } },
  QAR: { free: { monthly: 0, yearly: 0 }, basic: { monthly: 499, yearly: 4999 }, standard: { monthly: 999, yearly: 9999 }, premium: { monthly: 1499, yearly: 14999 } },
  KWD: { free: { monthly: 0, yearly: 0 }, basic: { monthly: 49, yearly: 499 }, standard: { monthly: 99, yearly: 999 }, premium: { monthly: 149, yearly: 1499 } },
  BHD: { free: { monthly: 0, yearly: 0 }, basic: { monthly: 49, yearly: 499 }, standard: { monthly: 99, yearly: 999 }, premium: { monthly: 149, yearly: 1499 } },
  OMR: { free: { monthly: 0, yearly: 0 }, basic: { monthly: 49, yearly: 499 }, standard: { monthly: 99, yearly: 999 }, premium: { monthly: 149, yearly: 1499 } },
};

const defaultCountry = gccCountries[0];
const defaultPricing = pricing.AED;

// Plan tiers driven by translations (single source of truth: src/i18n/ui.ts)
const tk = t as unknown as (key: string) => string;
const planTiers = ['free', 'basic', 'standard', 'premium'] as const;
const planFeatureKeys: Record<string, string[]> = {
  free: ['feature1', 'feature2', 'feature3', 'feature4'],
  basic: ['feature1', 'feature2', 'feature3', 'feature4', 'feature5'],
  standard: ['feature1', 'feature2', 'feature3', 'feature4', 'feature5'],
  premium: ['feature1', 'feature2', 'feature3', 'feature4', 'feature5', 'feature6'],
};
const plans = planTiers.map((tier) => ({
  id: tier,
  tier,
  name: tk(`pricing.plans.${tier}.name`),
  description: tk(`pricing.plans.${tier}.description`),
  badge: tk(`pricing.plans.${tier}.badge`),
  monthlyPrice: defaultPricing[tier].monthly,
  yearlyPrice: defaultPricing[tier].yearly,
  features: planFeatureKeys[tier].map((fk) => tk(`pricing.plans.${tier}.${fk}`)),
  cta: tk(`pricing.plans.${tier}.cta`),
  popular: tier === 'standard',
}));

const features = [
  t('pricing.features.no_fees'),
  t('pricing.features.money_back'),
  t('pricing.features.ssl'),
  t('pricing.features.support'),
  t('pricing.features.updates'),
];
---

<BaseLayout
  title={t('pricing.meta.title')}
  description={t('pricing.meta.desc')}
>
  <!-- Pricing Schema for SEO -->
  <PricingSchema />

  <Header />

  <main class="flex-1">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-purple-100 via-white to-purple-50 pt-32 pb-12">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <span class="inline-block mb-4 px-4 py-2 bg-purple-100 text-primary rounded-full text-sm font-medium">
          {t('pricing.hero.badge')}
        </span>
        <h1 class="mb-6 text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-gray-900">
          {t('pricing.hero.title.simple')} <span class="text-primary">{t('pricing.hero.title.transparent')}</span> {t('pricing.hero.title.pricing')}
        </h1>
        <p class="mx-auto mb-8 max-w-3xl text-xl text-gray-600">
          {t('pricing.hero.desc')}
        </p>

        <!-- Free Tier Banner -->
        <div class="mb-8">
          <div class="bg-gradient-to-r from-purple-50 via-purple-100 to-purple-50 border border-purple-200 rounded-xl p-6 max-w-4xl mx-auto">
            <div class="flex flex-col md:flex-row items-center justify-between gap-4">
              <div class="flex items-center gap-4 text-center md:text-left">
                <div class="hidden md:flex h-12 w-12 items-center justify-center rounded-full bg-purple-100">
                  <svg class="h-6 w-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-lg font-bold mb-1 text-gray-900">
                    {t('pricing.free_banner.title')}
                  </p>
                  <p class="text-sm text-gray-600">
                    {t('pricing.free_banner.subtitle')}
                  </p>
                </div>
              </div>
              <a href={`${URLS.app}/register/vendor`} class="inline-flex items-center gap-2 bg-primary text-white px-6 py-3 rounded-md font-semibold hover:bg-primary-light transition-colors whitespace-nowrap">
                {t('pricing.free_banner.cta')}
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Location Selector -->
        <div class="flex flex-col items-center gap-4 mb-8">
          <div class="flex items-center gap-2 text-sm text-gray-500">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span>{t('pricing.location.label')}</span>
          </div>
          <label for="countrySelect" class="sr-only">Select your country</label>
          <select
            id="countrySelect"
            class="w-64 px-4 py-2 border border-gray-300 rounded-md bg-white text-gray-900 font-medium focus:ring-2 focus:ring-primary focus:border-transparent"
            aria-label="Select country"
          >
            {gccCountries.map((country) => (
              <option value={country.currency} data-symbol={country.symbol}>
                {country.name} ({country.currency})
              </option>
            ))}
          </select>
        </div>

        <!-- Billing Toggle -->
        <div class="flex justify-center mb-10">
          <label for="billingToggle" class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" id="billingToggle" class="sr-only peer" />
            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-primary/20 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
            <span class="ml-3 font-semibold text-gray-900">
              {t('pricing.billing.annual_label')} <span class="text-primary">({t('pricing.billing.annual_discount')})</span>
            </span>
          </label>
        </div>

        <!-- Pricing Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-7xl mx-auto">
          {plans.map((plan, index) => (
            <div class={`group relative flex flex-col overflow-hidden rounded-2xl p-6 text-center transition-all duration-300 hover:-translate-y-1.5 ${
              plan.popular
                ? 'bg-gradient-to-br from-[#271060] via-[#595cff] to-[#52a8f2] text-white shadow-2xl ring-1 ring-white/20 md:-translate-y-3 hover:-translate-y-4'
                : 'border border-gray-200 bg-white shadow-sm hover:border-primary/30 hover:shadow-xl'
            }`}>
              {/* Subtle dot texture in the header area */}
              <div class={`pointer-events-none absolute inset-x-0 top-0 h-28 gfx-dots ${plan.popular ? 'text-white/15' : 'text-primary/10'}`} style="-webkit-mask-image:linear-gradient(#000,transparent);mask-image:linear-gradient(#000,transparent)"></div>
              {plan.popular && (
                <>
                  <div class="absolute top-0 right-0 -mt-6 -mr-6 h-28 w-28 rounded-full bg-white/10 blur-2xl"></div>
                  <div class="absolute bottom-0 left-0 -mb-6 -ml-6 h-24 w-24 rounded-full bg-[#5682f9]/30 blur-xl"></div>
                </>
              )}
              <div class="relative z-10 flex flex-1 flex-col">
                {plan.popular && (
                  <span class="badge-shimmer mx-auto mb-4 inline-flex items-center gap-1.5 rounded-full bg-white px-4 py-1.5 text-xs font-extrabold uppercase tracking-wider text-[#271060] shadow-lg ring-1 ring-black/5">
                    <svg class="h-3.5 w-3.5 fill-current text-amber-400" viewBox="0 0 24 24">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                    </svg>
                    {t('pricing.billing.popular_label')}
                  </span>
                )}
                <p class={`text-sm font-bold uppercase tracking-wider ${plan.popular ? 'text-white/80' : 'text-primary'}`}>
                  {plan.name}
                </p>
                <div class="mt-5 flex items-end justify-center gap-x-1.5">
                  <span class={`currency-symbol text-base font-semibold ${plan.popular ? 'text-white/70' : 'text-gray-400'}`}>
                    {defaultCountry.symbol}
                  </span>
                  <span
                    class={`price text-5xl font-extrabold tracking-tight ${plan.popular ? 'text-white' : 'text-gray-900'}`}
                    data-plan={plan.tier}
                    data-monthly={plan.monthlyPrice}
                    data-yearly={plan.yearlyPrice}
                  >
                    {plan.monthlyPrice}
                  </span>
                  <span class={`billing-period mb-1 text-sm font-medium ${plan.popular ? 'text-white/70' : 'text-gray-400'}`}>
                    /month
                  </span>
                </div>

                <p class={`billing-note mt-1 text-xs ${plan.popular ? 'text-white/70' : 'text-gray-400'}`}>
                  {t('pricing.billing.monthly_note')}
                </p>
                <p class={`mt-3 text-xs ${plan.popular ? 'text-white/80' : 'text-gray-500'}`}>
                  {plan.description}
                </p>

                <hr class={`my-5 ${plan.popular ? 'border-white/20' : 'border-gray-100'}`} />

                <ul class="flex flex-1 flex-col gap-2.5 text-start">
                  {plan.features.map((feature) => (
                    <li class="flex items-start gap-2.5">
                      <span class={`mt-0.5 flex h-4 w-4 flex-shrink-0 items-center justify-center rounded-full ${plan.popular ? 'bg-white/20 text-white' : 'bg-primary/10 text-primary'}`}>
                        <svg class="h-2.5 w-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                        </svg>
                      </span>
                      <span class={`text-sm ${plan.popular ? 'text-white/90' : 'text-gray-600'}`}>{feature}</span>
                    </li>
                  ))}
                </ul>

                <a
                  href={`${URLS.app}/register/vendor${plan.tier !== 'free' ? `?plan=${plan.id}` : ''}`}
                  class={`mt-6 block rounded-lg py-3 text-center text-base font-semibold transition-all duration-200 hover:ring-2 hover:ring-offset-2 ${
                    plan.popular
                      ? 'bg-white text-[#271060] hover:bg-white/90 hover:ring-white'
                      : 'bg-primary text-white hover:bg-primary-dark hover:ring-primary'
                  }`}
                >
                  {plan.cta}
                </a>
              </div>
            </div>
          ))}
        </div>

        <!-- Features list below pricing cards -->
        <div class="mt-12 flex flex-wrap justify-center gap-4 text-sm text-gray-500">
          {features.map((feature) => (
            <div class="flex items-center gap-2">
              <svg class="h-4 w-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>{feature}</span>
            </div>
          ))}
          <div class="flex items-center gap-2">
            <svg class="h-4 w-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span>{t('pricing.features.regional')}</span>
          </div>
        </div>

        <!-- Participation disclaimer -->
        <div class="mt-10 max-w-3xl mx-auto">
          <p class="flex items-start gap-2 justify-center text-sm text-gray-500 bg-gray-50 border border-gray-200 rounded-lg px-4 py-3">
            <svg class="h-4 w-4 mt-0.5 flex-shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>{t('pricing.disclaimer')}</span>
          </p>
        </div>
      </div>
    </section>

    <!-- Free First Month Section -->
    <section class="py-20 bg-gradient-to-br from-purple-100 via-white to-purple-50 relative overflow-hidden">
      <!-- Decorative background pattern -->
      <div class="absolute inset-0 opacity-30">
        <div class="absolute top-0 left-0 w-64 h-64 bg-purple-200 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 right-0 w-96 h-96 bg-purple-100 rounded-full blur-3xl"></div>
      </div>

      <div class="max-w-7xl mx-auto px-4 relative z-10">
        <div class="max-w-6xl mx-auto">
          <div class="text-center mb-12">
            <span class="inline-block mb-4 px-4 py-2 bg-purple-100 text-primary rounded-full text-sm font-medium">
              {t('pricing.free_month.badge')}
            </span>
            <h2 class="text-4xl md:text-5xl font-extrabold mb-4 text-gray-900">
              {t('pricing.free_month.title')} <span class="text-primary">{t('pricing.free_month.highlight')}</span>
            </h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">
              {t('pricing.free_month.desc')}
            </p>
          </div>

          <div class="grid md:grid-cols-3 gap-6 mb-12">
            <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
              <div class="h-12 w-12 rounded-lg bg-purple-100 flex items-center justify-center mb-4">
                <svg class="h-6 w-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <h3 class="text-lg font-bold mb-2 text-gray-900">
                {t('pricing.free_month.feature1.title')}
              </h3>
              <p class="text-gray-600">
                {t('pricing.free_month.feature1.desc')}
              </p>
            </div>

            <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
              <div class="h-12 w-12 rounded-lg bg-purple-100 flex items-center justify-center mb-4">
                <svg class="h-6 w-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <h3 class="text-lg font-bold mb-2 text-gray-900">
                {t('pricing.free_month.feature2.title')}
              </h3>
              <p class="text-gray-600">
                {t('pricing.free_month.feature2.desc')}
              </p>
            </div>

            <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
              <div class="h-12 w-12 rounded-lg bg-purple-100 flex items-center justify-center mb-4">
                <svg class="h-6 w-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </div>
              <h3 class="text-lg font-bold mb-2 text-gray-900">
                {t('pricing.free_month.feature3.title')}
              </h3>
              <p class="text-gray-600">
                {t('pricing.free_month.feature3.desc')}
              </p>
            </div>
          </div>

          <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-[#271060] via-primary to-[#3d2a7a] p-8 md:p-12 text-center shadow-2xl">
            <div class="pointer-events-none absolute inset-0 text-white/[0.06] gfx-grid"></div>
            <div class="pointer-events-none absolute -top-12 -right-12 h-44 w-44 rounded-full bg-secondary/30 blur-3xl"></div>
            <div class="pointer-events-none absolute -bottom-12 -left-12 h-44 w-44 rounded-full bg-accent/20 blur-3xl"></div>
            <div class="relative z-10">
              <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3.5 py-1.5 text-xs font-semibold text-white ring-1 ring-white/20 backdrop-blur">
                <span class="relative flex h-2 w-2">
                  <span class="absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75 motion-safe:animate-ping"></span>
                  <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400"></span>
                </span>
                Only 50 founding slots
              </span>
              <h3 class="mt-5 text-2xl md:text-3xl font-bold text-white">
                {t('pricing.free_month.cta.title')}
              </h3>
              <p class="mx-auto mt-3 max-w-2xl text-lg text-white/80">
                {t('pricing.free_month.cta.desc')}
              </p>
              <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
                <a href={`${URLS.app}/register/vendor`} class="group inline-flex items-center gap-2 rounded-xl bg-white px-8 py-4 text-lg font-bold text-[#271060] shadow-lg transition-all duration-200 hover:-translate-y-0.5 hover:shadow-xl">
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                  </svg>
                  {t('pricing.free_month.cta.btn')}
                  <svg class="h-5 w-5 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                  </svg>
                </a>
                <a href="/contact" class="rounded-xl border-2 border-white/40 px-8 py-4 text-lg font-semibold text-white transition-colors hover:bg-white/10">
                  {t('pricing.free_month.cta.contact')}
                </a>
              </div>
              <div class="mt-7 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-white/70">
                <div class="flex items-center gap-1.5">
                  <svg class="h-4 w-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
                  <span>{t('pricing.free_month.benefit1')}</span>
                </div>
                <div class="flex items-center gap-1.5">
                  <svg class="h-4 w-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
                  <span>{t('pricing.free_month.benefit2')}</span>
                </div>
                <div class="flex items-center gap-1.5">
                  <svg class="h-4 w-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
                  <span>{t('pricing.free_month.benefit3')}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script define:vars={{ monthlyNote: t('pricing.billing.monthly_note'), yearlyNote: t('pricing.billing.yearly_note'), perMonth: t('pricing.per_month'), perYear: t('pricing.per_year') }}>
  const pricing = {
    AED: { free: { monthly: 0, yearly: 0 }, basic: { monthly: 499, yearly: 4999 }, standard: { monthly: 999, yearly: 9999 }, premium: { monthly: 1499, yearly: 14999 } },
    SAR: { free: { monthly: 0, yearly: 0 }, basic: { monthly: 499, yearly: 4999 }, standard: { monthly: 999, yearly: 9999 }, premium: { monthly: 1499, yearly: 14999 } },
    QAR: { free: { monthly: 0, yearly: 0 }, basic: { monthly: 499, yearly: 4999 }, standard: { monthly: 999, yearly: 9999 }, premium: { monthly: 1499, yearly: 14999 } },
    KWD: { free: { monthly: 0, yearly: 0 }, basic: { monthly: 49, yearly: 499 }, standard: { monthly: 99, yearly: 999 }, premium: { monthly: 149, yearly: 1499 } },
    BHD: { free: { monthly: 0, yearly: 0 }, basic: { monthly: 49, yearly: 499 }, standard: { monthly: 99, yearly: 999 }, premium: { monthly: 149, yearly: 1499 } },
    OMR: { free: { monthly: 0, yearly: 0 }, basic: { monthly: 49, yearly: 499 }, standard: { monthly: 99, yearly: 999 }, premium: { monthly: 149, yearly: 1499 } },
  };

  let isYearly = false;
  let currentCurrency = 'AED';

  const countrySelect = document.getElementById('countrySelect');
  const billingToggle = document.getElementById('billingToggle');
  const priceElements = document.querySelectorAll('.price');
  const symbolElements = document.querySelectorAll('.currency-symbol');
  const billingPeriods = document.querySelectorAll('.billing-period');
  const billingNotes = document.querySelectorAll('.billing-note');

  function updatePrices() {
    const prices = pricing[currentCurrency];
    const selectedOption = countrySelect.querySelector('option[value="' + currentCurrency + '"]');
    const symbol = (selectedOption && selectedOption.dataset.symbol) || currentCurrency;

    priceElements.forEach((el) => {
      const plan = el.dataset.plan;
      if (plan && prices[plan]) {
        const price = isYearly ? prices[plan].yearly : prices[plan].monthly;
        el.textContent = price.toLocaleString();
      }
    });

    symbolElements.forEach((el) => {
      el.textContent = symbol;
    });

    billingPeriods.forEach((el) => {
      el.textContent = isYearly ? perYear : perMonth;
    });

    billingNotes.forEach((el) => {
      el.textContent = isYearly ? yearlyNote : monthlyNote;
    });
  }

  countrySelect && countrySelect.addEventListener('change', (e) => {
    currentCurrency = e.target.value;
    updatePrices();
  });

  billingToggle && billingToggle.addEventListener('change', (e) => {
    isYearly = e.target.checked;
    updatePrices();
  });
</script>
